// Tour Marketplace — Prisma schema
// DB: PostgreSQL. Uses JSON columns for multilingual fields (uz / ru / en).
//
// Design notes:
// - Multilingual content is stored as JSON: { "uz": "...", "ru": "...", "en": "..." }
//   This avoids a translations table explosion while keeping tours queryable.
// - Money is stored as integer minor units (tiyin/cents) to avoid float errors.
// - Soft delete via `deletedAt` on Tour so historical bookings stay valid.
// - Enums model the state machines (firm verification, tour, booking, payment).
// - Full-text search: `searchText` is a denormalised, maintained concatenation of
//   the multilingual content; a generated `tsvector` column + GIN index is added in
//   the `search_vector` migration (Prisma can't express generated columns, so it
//   lives in raw SQL — see prisma/migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  USER
  FIRM
  ADMIN
}

enum FirmStatus {
  PENDING // submitted, awaiting admin review
  VERIFIED // approved, may publish live tours
  SUSPENDED // temporarily blocked
  REJECTED
}

enum TourStatus {
  DRAFT // firm is still editing
  PUBLISHED // live and publicly visible
  UNPUBLISHED // hidden by firm
  ARCHIVED // retired
}

enum BookingStatus {
  REQUESTED // user submitted a request-to-book
  CONFIRMED // firm accepted (or auto-confirmed via instant departure)
  DECLINED // firm declined
  CANCELLED // user cancelled
  COMPLETED // tour happened
}

enum Currency {
  UZS
  USD
  EUR
}

enum DepartureStatus {
  OPEN // accepting bookings
  CLOSED // full or manually closed
  CANCELLED // called off
}

// Uzbekistan payment rails, plus MOCK for local/dev simulation.
enum PaymentProvider {
  MOCK
  PAYME
  CLICK
  UZUM
}

// Payment lifecycle: authorize (hold) on booking confirm, capture on completion.
enum PaymentStatus {
  PENDING // created, awaiting authorization
  AUTHORIZED // funds held
  CAPTURED // funds taken; commission split recorded
  REFUNDED // returned to traveller
  FAILED // provider rejected
  CANCELLED // hold released without capture
}

enum NotificationType {
  BOOKING_REQUESTED // firm: a new request arrived
  BOOKING_CONFIRMED // traveller: firm confirmed
  BOOKING_DECLINED // traveller: firm declined
  BOOKING_CANCELLED // firm: traveller cancelled
  BOOKING_COMPLETED // traveller: tour marked complete (leave a review!)
  PAYMENT_CAPTURED // both: payment settled
  PAYMENT_REFUNDED // traveller: refund issued
  FIRM_VERIFIED // firm: you can now publish
  FIRM_STATUS_CHANGED // firm: status changed
  REVIEW_RECEIVED // firm: a tour got a new review
}

// ---------- Core identity ----------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  firstName    String?
  lastName     String?
  phone        String?
  locale       String    @default("uz") // preferred UI language
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  // Telegram Mini App identity (set when the account is opened via the bot)
  telegramId       String?  @unique
  telegramUsername String?
  telegramPhotoUrl String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  firm          Firm?          @relation("FirmOwner")
  bookings      Booking[]
  reviews       Review[]
  refreshTokens RefreshToken[]
  notifications Notification[]

  @@index([role])
}

// Rotating refresh tokens (stored hashed) enable secure logout + reuse detection.
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

// ---------- Vendor (tour firm) ----------

model Firm {
  id          String     @id @default(cuid())
  ownerId     String     @unique
  owner       User       @relation("FirmOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String     @unique
  description Json? // multilingual { uz, ru, en }
  logoUrl     String?
  coverUrl    String?
  status      FirmStatus @default(PENDING)
  // Contact + trust signals
  email       String?
  phone       String?
  website     String?
  address     String?
  licenseNo   String? // tour operator license, for verification
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tours Tour[]

  @@index([status])
}

// ---------- Catalog ----------

model Category {
  id    String @id @default(cuid())
  slug  String @unique // e.g. "cultural", "adventure", "gastro"
  name  Json // multilingual
  icon  String?
  tours Tour[]
}

model Region {
  id    String @id @default(cuid())
  slug  String @unique // e.g. "samarkand", "bukhara", "tashkent"
  name  Json // multilingual
  tours Tour[]
}

model Tour {
  id            String     @id @default(cuid())
  firmId        String
  firm          Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  slug          String     @unique
  title         Json // multilingual { uz, ru, en }
  summary       Json? // short multilingual teaser
  description   Json? // long multilingual body
  itinerary     Json? // array of day objects, each multilingual
  status        TourStatus @default(DRAFT)

  // Pricing (minor units, e.g. tiyin). priceFrom is the headline price.
  priceFrom     Int
  currency      Currency   @default(UZS)

  // Facts used for filtering
  durationDays  Int        @default(1)
  durationHours Int? // for sub-day tours
  maxGroupSize  Int?
  minAge        Int?
  languages     String[]   @default([]) // tour-guide languages: ["uz","ru","en"]

  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id])
  regionId      String?
  region        Region?    @relation(fields: [regionId], references: [id])

  images        String[]   @default([]) // ordered image URLs; first is cover
  included      Json? // multilingual list of what's included
  excluded      Json? // multilingual list of what's not

  // Denormalized rating aggregates for cheap sorting/display
  ratingAvg     Float      @default(0)
  ratingCount   Int        @default(0)

  // Search: maintained concatenation of multilingual text (see search_vector migration).
  // `searchVector` is a generated tsvector column managed in raw SQL; declared here as
  // Unsupported so Prisma tracks (and does not drop) it.
  searchText    String     @default("")
  searchVector  Unsupported("tsvector")?

  // Growth: promoted/featured listings (monetisation)
  featured      Boolean    @default(false)
  featuredUntil DateTime?

  publishedAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  bookings      Booking[]
  reviews       Review[]
  departures    Departure[]

  @@index([status, deletedAt])
  @@index([firmId])
  @@index([categoryId])
  @@index([regionId])
  @@index([priceFrom])
  @@index([ratingAvg])
  @@index([featured, featuredUntil])
  @@index([searchVector], type: Gin)
}

// ---------- Availability & scheduling ----------

// A concrete departure date with finite seat inventory. Tours may have many.
// A booking can target a departure (seat-managed) or be an open request (legacy).
model Departure {
  id             String          @id @default(cuid())
  tourId         String
  tour           Tour            @relation(fields: [tourId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime?
  capacity       Int             @default(10)
  seatsBooked    Int             @default(0) // reserved seats (REQUESTED + CONFIRMED)
  priceOverride  Int? // minor units; overrides tour.priceFrom when set
  instantConfirm Boolean         @default(false) // skip firm approval, auto-confirm
  status         DepartureStatus @default(OPEN)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  bookings       Booking[]

  @@index([tourId, startDate])
  @@index([status])
}

// ---------- Transactions ----------

model Booking {
  id           String        @id @default(cuid())
  reference    String        @unique // human-friendly, e.g. "TM-8F3K2A"
  tourId       String
  tour         Tour          @relation(fields: [tourId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  departureId  String?
  departure    Departure?    @relation(fields: [departureId], references: [id])
  status       BookingStatus @default(REQUESTED)

  // Snapshot of what was requested (immutable even if the tour changes later)
  startDate    DateTime
  peopleCount  Int           @default(1)
  totalPrice   Int // minor units, snapshot at request time
  currency     Currency
  contactName  String
  contactPhone String
  contactEmail String
  note         String?

  firmResponse String? // message from firm on confirm/decline
  respondedAt  DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  review       Review?
  payment      Payment?

  @@index([userId])
  @@index([tourId])
  @@index([status])
  @@index([departureId])
}

// ---------- Payments (mock providers; hold-on-confirm, capture-on-completion) ----------

model Payment {
  id               String          @id @default(cuid())
  bookingId        String          @unique
  booking          Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider         PaymentProvider @default(MOCK)
  status           PaymentStatus   @default(PENDING)
  amount           Int // gross, minor units
  currency         Currency
  commissionAmount Int             @default(0) // platform cut, minor units
  netAmount        Int             @default(0) // firm payout, minor units
  providerRef      String? // provider-side transaction id
  authorizedAt     DateTime?
  capturedAt       DateTime?
  refundedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  events           PaymentEvent[]

  @@index([status])
  @@index([provider])
}

// Append-only audit trail of provider callbacks / state transitions.
model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type      String // e.g. "authorized", "captured", "webhook:paycom.check"
  payload   Json?
  createdAt DateTime @default(now())

  @@index([paymentId])
}

model Review {
  id        String   @id @default(cuid())
  tourId    String
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId String?  @unique // one review per booking; ensures reviewer actually booked
  booking   Booking? @relation(fields: [bookingId], references: [id])
  rating    Int // 1..5
  comment   String?
  firmReply String? // firm's public response to the review
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tourId, userId]) // one review per user per tour
  @@index([tourId])
}

// ---------- Notifications (in-app; email/SMS mocked to logger) ----------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json? // arbitrary context (bookingId, tourSlug, ...)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}
