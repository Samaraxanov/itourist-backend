# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tour_marketplace?schema=public"

# Auth — generate strong secrets: `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Payments — platform commission percent taken from each captured payment
PLATFORM_COMMISSION_PCT=10

# Media — local uploads dir (mock object storage), served at /uploads
UPLOAD_DIR=uploads

# Absolute base URL used to build upload URLs and the sitemap
PUBLIC_BASE_URL=http://localhost:4000

# Notifications — 'log' mocks email/SMS to the logger, 'off' disables
NOTIFY_CHANNEL=log

# Optional error tracking (leave blank to disable)
SENTRY_DSN=

# --- Telegram Mini App ---
# Bot token from @BotFather (enables /auth/telegram)
TELEGRAM_BOT_TOKEN=
# Telegram numeric user IDs treated as platform admins (comma-separated). Get yours from @userinfobot.
TELEGRAM_ADMIN_IDS=
# Public HTTPS URL of the mini app (tunnel or deployed), used by the bot setup script
TELEGRAM_WEBAPP_URL=
